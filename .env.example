# Do not commit real secrets. Copy to .env.secrets on the host or inject via the platform secret store.
# Provider keys/OAuth.
# OPENAI_API_KEY is optional; Codex OAuth uses CODEX_AUTH_PATH instead.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
CODEX_AUTH_PATH=./codex-auth.json

# Caller-auth map for ingress. Each service gets its own token mapped to a caller name.
# Prefer hashed storage with scripts/register_consumer_key.py, which writes SHA-256(token) -> caller.
# Legacy plaintext map is still supported for local/dev compatibility; do not use known example tokens in production.
CALLER_KEYS_JSON={}
CALLER_KEYS_SHA256_JSON={}

# Dashboard/admin auth. Generate the password hash with:
# python - <<'PY'
# import getpass, hashlib
# print(hashlib.sha256(getpass.getpass('dashboard password: ').encode()).hexdigest())
# PY
DASHBOARD_PASSWORD_SHA256=
DASHBOARD_SESSION_SECRET=
# Trusted-header admin auth is disabled by default. Only set both vars behind a reverse proxy that strips client-supplied copies.
DASHBOARD_TRUSTED_USER_HEADER=
DASHBOARD_TRUSTED_USER_SECRET=
# Local-dev only: set to 1 to skip dashboard auth entirely (every request is a
# local admin). NEVER set this on a deployment reachable by anyone but you.
DASHBOARD_NO_AUTH=

# Host bind is loopback-only by compose.yml. Change only if fronted by private LB/service mesh.
LLM_ROUTER_HOST_PORT=8080
# Public OpenAI-compatible base URL shown in the dashboard's "key is ready" handoff blurb.
PUBLIC_BASE_URL=http://127.0.0.1:8080/v1
RATE_PER_MIN=600
BURST=200
LOG_LEVEL=INFO
